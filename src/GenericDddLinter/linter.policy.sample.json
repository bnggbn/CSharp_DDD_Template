{
  "requireAsciiPath": true,
  "dependencyRules": [
    {
      "ruleId": "DEP001",
      "pathContains": "/domain/",
      "forbiddenNamespaces": [
        "DddStarter.Application",
        "DddStarter.Infrastructure",
        "DddStarter.Bootstrap",
        "DddStarter.Controller"
      ]
    },
    {
      "ruleId": "DEP002",
      "pathContains": "/application/contracts/",
      "forbiddenNamespaces": [
        "DddStarter.Infrastructure",
        "DddStarter.Bootstrap",
        "DddStarter.Controller"
      ]
    }
  ],
  "namingRules": [
    {
      "ruleId": "NAME001",
      "pathContains": "/application/contracts/",
      "typeRegex": "\\binterface\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "I",
      "requiredSuffix": ""
    },
    {
      "ruleId": "NAME002",
      "pathContains": "/application/use-cases/",
      "typeRegex": "\\bclass\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "UseCase"
    },
    {
      "ruleId": "VO000",
      "pathContains": "/domain/value-objects/",
      "typeRegex": "\\bclass\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "Vo"
    },
    {
      "ruleId": "INFH001",
      "pathContains": "/infrastructure/helpers/",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "Helper"
    },
    {
      "ruleId": "INFX001",
      "pathContains": "/infrastructure/extensions/",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "Extensions"
    },
    {
      "ruleId": "INFC001",
      "pathContains": "/infrastructure/constants/",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "Constants"
    }
  ],
  "pathTypeRules": [
    {
      "ruleId": "PATH001",
      "typeRegex": "\\bclass\\s+([A-Za-z0-9_]*Monitor)\\b",
      "requiredPathContains": "/monitors/"
    },
    {
      "ruleId": "PATH002",
      "typeRegex": "\\bclass\\s+([A-Za-z0-9_]*UseCase)\\b",
      "requiredPathContains": "/use-cases/"
    },
    {
      "ruleId": "PATH003",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]*Helper)\\b",
      "requiredPathContains": "/infrastructure/helpers/"
    },
    {
      "ruleId": "PATH004",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]*Extensions)\\b",
      "requiredPathContains": "/infrastructure/extensions/"
    },
    {
      "ruleId": "PATH005",
      "typeRegex": "\\b(?:static\\s+)?class\\s+([A-Za-z0-9_]*Constants)\\b",
      "requiredPathContains": "/infrastructure/constants/"
    }
  ],
  "fileNamingRule": {
    "ruleId": "FILE001",
    "enabled": true
  },
  "mediatRScopeRules": [
    {
      "ruleId": "MEDIATR001",
      "forbiddenPathContains": "/domain/",
      "forbiddenUsing": "using MediatR"
    },
    {
      "ruleId": "MEDIATR002",
      "forbiddenPathContains": "/infrastructure/",
      "forbiddenUsing": "using MediatR"
    }
  ],
  "configMutationRule": {
    "assignmentRuleId": "CFG001",
    "fileWriteRuleId": "CFG002",
    "overridePropertyName": "MonitorSeverityOverrides",
    "settingsFileName": "appsettings.json",
    "allowedAssignmentPathContains": [
      "/infrastructure/configuration/",
      "/infrastructure/config/"
    ],
    "allowedSettingsWritePathContains": [
      "/infrastructure/configuration/",
      "/infrastructure/config/"
    ]
  },
  "cqrsCommandFileRule": {
    "ruleId": "CQRS100",
    "commandsPathContains": "/application/use-cases/commands/"
  },
  "cqrsQueryFileRule": {
    "ruleId": "CQRS101",
    "queriesPathContains": "/application/use-cases/queries/"
  },
  "severityMutationRule": {
    "ruleId": "SEV001",
    "targetMethodName": "SetSeverity",
    "allowedPathContains": [
      "/application/use-cases/",
      "/infrastructure/configuration/"
    ]
  },
  "constructorInterfaceRule": {
    "ruleId": "DIP001",
    "enabled": true,
    "targetPathContains": [
      "/application/use-cases/",
      "/controller/",
      "/bootstrap/"
    ]
  },
  "interfaceMockRule": {
    "ruleId": "MOCK001",
    "enabled": true,
    "interfacePathContains": [
      "/application/contracts/",
      "/infrastructure/database/abstractions/"
    ],
    "searchPathContains": [
      "/tests/",
      "/src/"
    ],
    "allowedMockSuffixes": [
      "Mock",
      "Fake",
      "Stub"
    ]
  },
  "constantsClassRule": {
    "ruleId": "CONST001",
    "enabled": true,
    "targetPathContains": [
      "/infrastructure/constants/"
    ],
    "classSuffix": "Constants"
  }
}
