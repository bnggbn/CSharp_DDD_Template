{
  "AppSettings": {
    "ConnectionStringProvider": {
      "Kind": "DataProtection",
      "EnvironmentVariablePrefix": "ConnectionStrings__"
    },
    "AwsSecretsManager": {
      "RegionSystemName": "ap-northeast-1",
      "SecretIdPrefix": "dddstarter/dev/connection-strings/",
      "ConnectionSecretIds": {
        "Primary": "dddstarter/dev/connection-strings/primary"
      }
    },
    "Database": {
      "DefaultConnectionName": "Primary",
      "EncryptedConnectionStringPaths": {
        "Primary": "secrets/primary.connection-string.protected.txt",
        "Reporting": "secrets/reporting.connection-string.protected.txt"
      }
    },
    "DataProtection": {
      "ApplicationName": "DddStarter",
      "KeyDirectory": "keys",
      "ConnectionStringPurpose": "ConnectionString"
    },
    "MonitorSeverityOverrides": {}
  }
}
