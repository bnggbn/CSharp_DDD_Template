{
  "requireAsciiPath": true,
  "ruleDescriptions": {
    "CQRS100": "Command records must be nested in '*BusinessUseCase' under application/use-cases.",
    "CQRS101": "Query records must be nested in '*BusinessUseCase' under application/use-cases.",
    "CQRS102": "Use-case files must be '*UseCase.cs' and contain only record command/query members.",
    "CQRS103": "Command/query records must not use custom inheritance; only approved request interfaces are allowed.",
    "IMM001": "Command/query records must remain immutable: init-only properties and readonly fields only.",
    "FLOW001": "Workflow constructors may only depend on ISender.",
    "FLOW002": "Workflow methods are dispatch-only: they may only create command/query requests and call ISender.Send(...).",
    "FLOW003": "Handlers must not orchestrate by depending on mediator sender/publisher or dispatching nested requests.",
    "CTRL001": "Controller constructors must stay in workflow/framework dependency scope."
  },
  "dependencyRules": [
    {
      "ruleId": "DEP001",
      "pathContains": "/domain/",
      "forbiddenNamespaces": [
        "YourProject.Application",
        "YourProject.Infrastructure",
        "YourProject.Bootstrap",
        "YourProject.Controller"
      ]
    }
  ],
  "namingRules": [
    {
      "ruleId": "NAME001",
      "pathContains": "/application/contracts/",
      "typeRegex": "\\binterface\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "I",
      "requiredSuffix": ""
    },
    {
      "ruleId": "NAME002",
      "pathContains": "/application/use-cases/",
      "typeRegex": "\\bclass\\s+([A-Za-z0-9_]+)",
      "requiredPrefix": "",
      "requiredSuffix": "UseCase"
    }
  ],
  "cqrsCommandFileRule": {
    "ruleId": "CQRS100",
    "commandsPathContains": "/application/use-cases/"
  },
  "cqrsQueryFileRule": {
    "ruleId": "CQRS101",
    "queriesPathContains": "/application/use-cases/"
  },
  "useCaseFileRule": {
    "ruleId": "CQRS102",
    "enabled": true,
    "useCasesPathContains": "/application/use-cases/"
  },
  "requestImmutabilityRule": {
    "ruleId": "IMM001",
    "enabled": true,
    "requestsPathContains": "/application/use-cases/"
  },
  "cqrsInheritanceRule": {
    "ruleId": "CQRS103",
    "enabled": true,
    "requestsPathContains": "/application/use-cases/",
    "allowedInterfaceTypeNames": [
      "IRequest",
      "IRequireValidation"
    ]
  },
  "workflowConstructorRule": {
    "ruleId": "FLOW001",
    "enabled": true,
    "workflowsPathContains": "/application/workflows/",
    "allowedDependencyTypeNames": [
      "ISender"
    ]
  },
  "workflowDispatchRule": {
    "ruleId": "FLOW002",
    "enabled": true,
    "workflowsPathContains": "/application/workflows/",
    "allowedRequestSuffixes": [
      "Command",
      "Query"
    ]
  },
  "handlerDispatchRule": {
    "ruleId": "FLOW003",
    "enabled": true,
    "handlersPathContains": "/application/handlers/",
    "forbiddenDependencyTypeNames": [
      "ISender",
      "IMediator",
      "IPublisher"
    ],
    "forbiddenInvocationNames": [
      "Send",
      "Publish"
    ]
  },
  "controllerWorkflowRule": {
    "ruleId": "CTRL001",
    "enabled": true,
    "controllersPathContains": "/controller/",
    "allowedDependencyTypeNames": [
      "ILogger",
      "IConfiguration",
      "IServiceProvider"
    ],
    "allowedDependencySuffixes": [
      "Workflow"
    ]
  }
}
